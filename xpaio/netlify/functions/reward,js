const axios = require('axios');

exports.handler = async (event) => {
    // 1. 보안을 위해 POST 요청만 허용
    if (event.httpMethod !== "POST") {
        return { statusCode: 405, body: "Method Not Allowed" };
    }

    try {
        const { username } = JSON.parse(event.body);
        const apiKey = process.env.PI_API_KEY; // 넷리파이에 저장한 그 키!

        // 2. 파이 서버에 결제(전송) 요청 보내기
        // 여기서 은하수님의 지갑(B) 설정이 사용됩니다.
        const response = await axios.post('https://api.minepi.com/v2/payments', {
            payment: {
                amount: 10, // 보낼 수량
                memo: "XPAIO 에어드랍 보상",
                metadata: { type: "airdrop" },
                uid: username
            }
        }, {
            headers: { Authorization: `Key ${apiKey}` }
        });

        return {
            statusCode: 200,
            body: JSON.stringify({ message: "전송 성공!", data: response.data })
        };

    } catch (error) {
        return {
            statusCode: 500,
            body: JSON.stringify({ error: error.message })
        };
    }
};